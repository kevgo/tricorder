{
  "_comment": "Generated by `tricorder init`. Hooks read by Claude Code AND Code Puppy. Edit freely - this file is yours.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/tricorder-hooks/post_write.sh",
            "statusMessage": "Tricorder: checking the project...",
            "timeout": 120
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/tricorder-hooks/pre_commit.sh",
            "statusMessage": "Tricorder: pre-commit check...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
